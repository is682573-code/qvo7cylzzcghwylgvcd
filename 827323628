GGshopCrosshair = { objects = {}, angle = 0, hue = 0 }

function GGshopCrosshair.getColor()
    if Settings.Crosshair.Rainbow then
        return Color3.fromHSV(GGshopCrosshair.hue, 1, 1)
    else
        return Settings.Crosshair.Color
    end
end

function GGshopCrosshair.addLine(x1, y1, x2, y2, color, thick, outline)
    local line = Drawing.new("Line")
    line.From = Vector2.new(x1, y1)
    line.To = Vector2.new(x2, y2)
    line.Color = color
    line.Thickness = thick or Settings.Crosshair.Thickness
    line.Visible = true
    table.insert(GGshopCrosshair.objects, line)
    if outline and Settings.Crosshair.Outline then
        local ol = Drawing.new("Line")
        ol.From = Vector2.new(x1, y1)
        ol.To = Vector2.new(x2, y2)
        ol.Color = Settings.Crosshair.OutlineColor
        ol.Thickness = thick + Settings.Crosshair.OutlineThickness
        ol.Visible = true
        table.insert(GGshopCrosshair.objects, ol)
    end
end

function GGshopCrosshair.addCircle(cx, cy, radius, color, thick, filled, outline)
    local circ = Drawing.new("Circle")
    circ.Position = Vector2.new(cx, cy)
    circ.Radius = radius
    circ.Color = color
    circ.Thickness = thick or 1
    circ.Filled = filled or false
    circ.Visible = true
    table.insert(GGshopCrosshair.objects, circ)
    if outline and Settings.Crosshair.Outline then
        local ol = Drawing.new("Circle")
        ol.Position = Vector2.new(cx, cy)
        ol.Radius = radius + Settings.Crosshair.OutlineThickness
        ol.Color = Settings.Crosshair.OutlineColor
        ol.Thickness = thick
        ol.Filled = false
        ol.Visible = true
        table.insert(GGshopCrosshair.objects, ol)
    end
end

function GGshopCrosshair.drawStyle(cx, cy, style, scale, gap, len, thick, color, dot, dotSize, angle)
    local function rot(x, y, a)
        local c = math.cos(a)
        local s = math.sin(a)
        return x * c - y * s, x * s + y * c
    end
    local L = len * scale
    local G = gap * scale
    local T = thick * scale
    local D = dotSize * scale
    local points = {}
    if style == 1 then
        points = {{0, -L, 0, -G}, {0, G, 0, L}, {-L, 0, -G, 0}, {G, 0, L, 0}}
    elseif style == 2 then
        points = {{0, -L, 0, L}, {-L, 0, L, 0}}
    elseif style == 3 then
        GGshopCrosshair.addCircle(cx, cy, D, color, T, true, true)
        return
    elseif style == 4 then
        GGshopCrosshair.addCircle(cx, cy, L * 0.8, color, T, false, true)
        GGshopCrosshair.addCircle(cx, cy, D, color, T, true, true)
        return
    elseif style == 5 then
        points = {{0, -L, 0, -G}, {0, G, 0, L}, {-L, 0, -G, 0}, {G, 0, L, 0}}
    elseif style == 6 then
        points = {{-L, -L, -G, -G}, {G, G, L, L}, {-L, L, -G, G}, {G, -G, L, -L}}
    elseif style == 7 then
        local h = L * 0.7
        points = {{-h, -h, h, -h}, {h, -h, h, h}, {h, h, -h, h}, {-h, h, -h, -h}}
    elseif style == 8 then
        points = {{0, -L, 0, -G}, {-L, 0, -G, 0}, {G, 0, L, 0}}
    elseif style == 9 then
        points = {{0, G, 0, L}, {-L, 0, -G, 0}, {G, 0, L, 0}}
    elseif style == 10 then
        points = {{0, -L, 0, -G}, {0, G, 0, L}}
    elseif style == 11 then
        points = {{-L, 0, -G, 0}, {G, 0, L, 0}}
    elseif style == 12 then
        GGshopCrosshair.addCircle(cx, cy, L * 0.8, color, T, false, true)
        return
    elseif style == 13 then
        points = {{0, -L, 0, -G}, {0, G, 0, L}, {-L, 0, -G, 0}, {G, 0, L, 0}}
        GGshopCrosshair.addCircle(cx, cy, L * 0.9, color, T, false, true)
    elseif style == 14 then
        local r = L * 0.7
        points = {{0, -r, r, 0}, {r, 0, 0, r}, {0, r, -r, 0}, {-r, 0, 0, -r}}
    elseif style == 15 then
        points = {
            {0, -L, 0, -G}, {0, G, 0, L}, {-L, 0, -G, 0}, {G, 0, L, 0},
            {-L, -L, -G, -G}, {G, G, L, L}, {-L, L, -G, G}, {G, -G, L, -L}
        }
    end
    for _, p in ipairs(points) do
        local x1, y1 = rot(p[1], p[2], angle)
        local x2, y2 = rot(p[3], p[4], angle)
        GGshopCrosshair.addLine(cx + x1, cy + y1, cx + x2, cy + y2, color, T, true)
    end
    if dot and style ~= 3 then
        GGshopCrosshair.addCircle(cx, cy, D, color, T, true, true)
    end
end

function GGshopCrosshair.update()
    if not Settings.Crosshair.Enabled then
        for _, obj in ipairs(GGshopCrosshair.objects) do obj.Visible = false end
        return
    end
    local cx = Camera.ViewportSize.X / 2
    local cy = Camera.ViewportSize.Y / 2
    local style = Settings.Crosshair.Style
    if type(style) == "string" then style = tonumber(style) or 1 end
    local scale = Settings.Crosshair.Scale
    local gap = Settings.Crosshair.Gap
    local len = Settings.Crosshair.Length
    local thick = Settings.Crosshair.Thickness
    local dot = Settings.Crosshair.Dot
    local dotSize = Settings.Crosshair.DotSize
    local color = GGshopCrosshair.getColor()
    if Settings.Crosshair.Rotating then
        GGshopCrosshair.angle = GGshopCrosshair.angle + Settings.Crosshair.RotationSpeed * 2 * math.pi / 60
        GGshopCrosshair.angle = GGshopCrosshair.angle % (2 * math.pi)
    else
        GGshopCrosshair.angle = 0
    end
    if Settings.Crosshair.Rainbow then
        GGshopCrosshair.hue = (GGshopCrosshair.hue + Settings.Crosshair.RainbowSpeed / 60) % 1
    end
    for _, obj in ipairs(GGshopCrosshair.objects) do obj:Remove() end
    GGshopCrosshair.objects = {}
    if Settings.Crosshair.CustomMode then
        for _, lineDef in ipairs(Settings.Crosshair.CustomLines) do
            local col = lineDef.color or color
            GGshopCrosshair.addLine(cx + lineDef.x1, cy + lineDef.y1, cx + lineDef.x2, cy + lineDef.y2, col, thick, true)
        end
    else
        GGshopCrosshair.drawStyle(cx, cy, style, scale, gap, len, thick, color, dot, dotSize, GGshopCrosshair.angle)
    end
end

