local function IsValidAimTarget(character)
    if not Settings.BotsAim.Enabled then return false end
    local humanoid = character:FindFirstChildOfClass("Humanoid")
    if not humanoid or humanoid.Health <= 0 then return false end
    if Players:GetPlayerFromCharacter(character) then return false end

    local faction = GetNPCFaction(character)
    if faction == "Boss" then
        if character.Name:lower():find("dozer") and not Settings.BotsAim.TargetDozer then return false end
        if character.Name:lower():find("anton") and not Settings.BotsAim.TargetAnton then return false end
        return true
    elseif faction == "Bandit" then
        return Settings.BotsAim.TargetBandits
    elseif faction == "Scav" then
        return Settings.BotsAim.TargetScavs
    elseif faction == "Soviet" then
        return Settings.BotsAim.TargetSoviet
    elseif faction == "TFZ" then
        return Settings.BotsAim.TargetTFZ
    elseif faction == "Trader" then
        return Settings.BotsAim.TargetTraders
    elseif faction == "Other" then
        return Settings.BotsAim.TargetOther
    end
    return false
end

local function GetClosestNPC()
    local mousePos = UserInputService:GetMouseLocation()
    local closest = nil
    local bestScore = math.huge
    local fovRadius = Settings.Aimbot.FOV

    for char, esp in pairs(Settings.NPCObjects) do
        if not IsValidAimTarget(char) then continue end
        local center = NPCPositionCache[char] and NPCPositionCache[char].center
        if not center then
            center, _ = GetNPCCenterPoint(char)
            if not center then continue end
        end

        local dist = (Camera.CFrame.Position - center).Magnitude
        if dist > Settings.BotsAim.MaxDistance then continue end

        local visible = true
        if Settings.Aimbot.WallCheck then
            visible = IsTargetVisible(char, {"Head", "HumanoidRootPart"})
        end
        if not visible then continue end

        local screenPos, onScreen = Camera:WorldToViewportPoint(center)
        if not onScreen then continue end

        local screenVec = Vector2.new(screenPos.X, screenPos.Y)
        local fovDist = (screenVec - mousePos).Magnitude

        if Settings.BotsAim.UseFOV and fovDist > fovRadius then
            continue
        end

        local score
        if Settings.BotsAim.PriorityMode == "FOV" then
            score = fovDist
        elseif Settings.BotsAim.PriorityMode == "Distance" then
            score = dist
        elseif Settings.BotsAim.PriorityMode == "LowHealth" then
            local hum = char:FindFirstChildOfClass("Humanoid")
            local health = hum and hum.Health or 0
            score = health
        end

        if score < bestScore then
            bestScore = score
            closest = char
        end
    end

    if closest then
        local partName = Settings.BotsAim.LockPart
        local targetPart = closest:FindFirstChild(partName)
        if not targetPart then
            targetPart = closest:FindFirstChild("Head") or closest:FindFirstChild("HumanoidRootPart")
        end
        if targetPart and targetPart:IsA("BasePart") then
            return targetPart
        end
    end
    return nil
end

local function GetClosestTarget()
    if not Settings.Aimbot.Enabled then return nil end
    local mousePos = UserInputService:GetMouseLocation()
    local closest, closestDist = nil, Settings.Aimbot.FOV

    for _, plr in ipairs(Players:GetPlayers()) do
        if plr == LocalPlayer then continue end
        if Settings.Aimbot.TeamCheck and plr.Team == LocalPlayer.Team then continue end
        local char = plr.Character
        if not char then continue end
        local part = char:FindFirstChild(Settings.Aimbot.LockPart) or char:FindFirstChild("Head") or char:FindFirstChild("HumanoidRootPart")
        if not part then continue end
        if Settings.Aimbot.WallCheck then
            if not IsTargetVisible(char, {part.Name}) then continue end
        end
        if Settings.Aimbot.AliveCheck then
            local hum = char:FindFirstChildOfClass("Humanoid")
            if not hum or hum.Health <= 0 then continue end
        end
        local pos, onScreen = Camera:WorldToViewportPoint(part.Position)
        if not onScreen then continue end
        local screenPos = Vector2.new(pos.X, pos.Y)
        local dist = (screenPos - mousePos).Magnitude
        if dist < closestDist then
            closestDist = dist
            closest = part
        end
    end

    if not closest and Settings.BotsAim.Enabled then
        local npcPart = GetClosestNPC()
        if npcPart then
            closest = npcPart
        end
    end

    return closest
end

