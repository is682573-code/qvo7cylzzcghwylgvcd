local hiddenUIs = {}
local originalAutoRotate = nil
local originalCollision = {}
local lastMousePos = UserInputService:GetMouseLocation()

local function makeCharVisible(char)
    if not char then return end
    for _, part in ipairs(char:GetDescendants()) do
        if part:IsA("BasePart") then
            part.LocalTransparencyModifier = 0
            part.Transparency = math.min(part.Transparency, 0.5)
            if originalCollision[part] == nil then originalCollision[part] = part.CanCollide end
            part.CanCollide = false
        end
    end
    local hum = char:FindFirstChildOfClass("Humanoid")
    if hum then hum:SetAttribute("ForceVisible", true) end
end

local function restoreCollision(char)
    for part, old in pairs(originalCollision) do
        if part and part.Parent then pcall(function() part.CanCollide = old end) end
    end
    originalCollision = {}
end

local function hideUI(hide)
    if not Settings.ThirdPerson.HideUI then return end
    if hide then
        local containers = {CoreGui, LocalPlayer.PlayerGui}
        for _, cont in ipairs(containers) do
            if cont then
                for _, ch in ipairs(cont:GetChildren()) do
                    if ch:IsA("ScreenGui") and ch.Name ~= "GGshopXenoMenu" and ch.Name ~= "InventorySpy" and ch.Name ~= "GGSplash" then
                        if ch.Enabled then hiddenUIs[ch] = true; ch.Enabled = false end
                    end
                end
            end
        end
    else
        for guiObj, _ in pairs(hiddenUIs) do
            if guiObj and guiObj.Parent then pcall(function() guiObj.Enabled = true end) end
        end
        hiddenUIs = {}
    end
end

local function getOrbitCFrame(char, dist, yawRad, pitchRad, offset)
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if not root then return nil end
    local pivot = root.Position + Vector3.new(0, offset, 0)
    local dirX = math.sin(yawRad) * math.cos(pitchRad)
    local dirY = math.sin(pitchRad)
    local dirZ = math.cos(yawRad) * math.cos(pitchRad)
    local dir = Vector3.new(dirX, dirY, dirZ).Unit
    local desired = pivot + dir * dist
    if Settings.ThirdPerson.CollisionCheck and dist > 0.1 then
        local params = RaycastParams.new()
        params.FilterType = Enum.RaycastFilterType.Blacklist
        params.FilterDescendantsInstances = {char, Camera}
        local hit = Workspace:Raycast(pivot, dir * dist, params)
        if hit then
            local hitDist = (hit.Position - pivot).Magnitude
            local newD = math.max(Settings.ThirdPerson.MinDistance, hitDist - 0.3)
            desired = pivot + dir * newD
            if newD < dist then targetDist = newD end
        end
    end
    return CFrame.lookAt(desired, pivot)
end

function SetThirdPersonActive(active)
    if active == thirdPersonActive then return end
    thirdPersonActive = active
    local char = LocalPlayer.Character
    if active then
        if char then
            makeCharVisible(char)
            local hum = char:FindFirstChildOfClass("Humanoid")
            if hum then originalAutoRotate = hum.AutoRotate; hum.AutoRotate = false end
        end
        if Settings.ThirdPerson.ZoomDisabledDuringHold then
            originalZoomState.active = zoomActive
            originalZoomState.toggled = zoomToggled
            originalZoomState.fov = Camera.FieldOfView
            if zoomActive or zoomToggled then zoomActive = false; zoomToggled = false; Camera.FieldOfView = originalZoomState.fov end
        end
        if char and char:FindFirstChild("HumanoidRootPart") and (yaw == 0 and pitch == 0.2) then
            local pivot = char.HumanoidRootPart.Position + Vector3.new(0, Settings.ThirdPerson.HeightOffset, 0)
            local dir = (Camera.CFrame.Position - pivot).Unit
            yaw = math.atan2(dir.X, dir.Z)
            pitch = math.asin(math.clamp(dir.Y, -1, 1))
        end
        targetDist = Settings.ThirdPerson.Distance
        currentDist = targetDist
        Camera.CameraType = Enum.CameraType.Scriptable
        UserInputService.MouseBehavior = Enum.MouseBehavior.LockCenter
        hideUI(true)
        if Settings.Misc.HideOverlay then watermark.Visible = false end
    else
        if char then
            local hum = char:FindFirstChildOfClass("Humanoid")
            if hum and originalAutoRotate ~= nil then hum.AutoRotate = originalAutoRotate; originalAutoRotate = nil end
            restoreCollision(char)
        end
        if Settings.ThirdPerson.ZoomDisabledDuringHold then
            if originalZoomState.toggled then zoomToggled = true; Camera.FieldOfView = Settings.Zoom.ZoomFOV
            elseif originalZoomState.active then zoomActive = true; Camera.FieldOfView = Settings.Zoom.ZoomFOV end
        end
        Camera.CameraType = Enum.CameraType.Custom
        UserInputService.MouseBehavior = Enum.MouseBehavior.Default
        hideUI(false)
        if Settings.Misc.HideOverlay then watermark.Visible = true end
    end
end

