RunService.RenderStepped:Connect(function(dt)
    Camera = Workspace.CurrentCamera
    frameCount = frameCount + 1
    if frameCount % Settings.FRAME_SKIP == 0 then
        UpdateESP()
        UpdateAdminESP()
        UpdateNPCESP()
        UpdateMapESP()
        UpdateLootESP()
    end
    ApplySpeedHack()
    ApplyWeaponMods()
    ApplyNoMuzzleFlash()
    if Settings.Combat.NoRecoil ~= Settings.lastNoRecoilState then
        ApplySimpleNoRecoil()
        Settings.lastNoRecoilState = Settings.Combat.NoRecoil
    end
    if Settings.Aimbot.ShowFOV and Settings.Aimbot.Enabled then
        local mp = UserInputService:GetMouseLocation()
        fovCircle.Position = mp
        fovCircle.Radius = Settings.Aimbot.FOV
        fovCircle.Color = Settings.Aimbot.FOVSettings.Color
        fovCircle.Thickness = Settings.Aimbot.FOVSettings.Thickness
        fovCircle.Transparency = Settings.Aimbot.FOVSettings.Transparency
        fovCircle.Visible = true
    else fovCircle.Visible = false end
    if not thirdPersonActive and Settings.holdingKey and Settings.Aimbot.Enabled then
        local target = GetClosestTarget()
        if target then
            local targetPos = target.Position
            local currentCF = Camera.CFrame
            local newCF = CFrame.lookAt(currentCF.Position, targetPos)
            local char = target.Parent
            local isPlayer = char and Players:GetPlayerFromCharacter(char) ~= nil
            local smooth = isPlayer and Settings.Aimbot.Smoothness or Settings.BotsAim.Smoothness
            Camera.CFrame = currentCF:Lerp(newCF, smooth)
        end
    end
    if Settings.Combat.TargetHealth.Enabled then
        local aim = GetClosestTarget()
        if aim then
            local hum = aim.Parent and aim.Parent:FindFirstChildOfClass("Humanoid")
            if hum and hum.Health > 0 then
                if hum.Health ~= lastTargetHealth then
                    lastTargetHealth = hum.Health
                    targetHealthText.Text = string.format("HP: %d", hum.Health)
                end
                local vs = Camera.ViewportSize
                local pos = (Settings.Combat.TargetHealth.Position == "BelowCrosshair") and Vector2.new(vs.X/2, vs.Y/2+40) or Vector2.new(20,40)
                targetHealthText.Position = pos
                targetHealthText.Size = Settings.Combat.TargetHealth.FontSize
                targetHealthText.Color = Settings.Combat.TargetHealth.Color
                targetHealthText.Visible = true
            else targetHealthText.Visible = false end
        else targetHealthText.Visible = false end
    else targetHealthText.Visible = false end
    if Settings.Combat.AntiSniper.Enabled then
        local now = tick()
        if now - lastWarningTime > Settings.Combat.AntiSniper.Cooldown then
            local aiming = checkIfBeingAimed()
            if aiming then
                lastWarningTime = now
                local txt = Settings.Combat.AntiSniper.WarningText
                if Settings.Combat.AntiSniper.ShowName then txt = txt .. "\n" .. aiming.Name end
                warningText.Text = txt
                local vs = Camera.ViewportSize
                warningText.Position = Vector2.new(vs.X/2, vs.Y/2-100)
                warningText.Size = Settings.Combat.AntiSniper.WarningSize
                warningText.Color = Settings.Combat.AntiSniper.WarningColor
                warningText.Visible = true
                if Settings.Combat.AntiSniper.Sound then
                    pcall(function()
                        local s = Instance.new("Sound")
                        s.SoundId = Settings.HitmarkerSoundId
                        s.Parent = workspace
                        s:Play()
                        game:GetService("Debris"):AddItem(s, 1)
                    end)
                end
                task.delay(1, function() warningText.Visible = false end)
            else warningText.Visible = false end
        end
    else warningText.Visible = false end
    if Settings.Triggerbot.Enabled then
        local k = keyMap[Settings.Triggerbot.Key]
        local down = false
        if k then
            if k.EnumType == Enum.KeyCode then down = UserInputService:IsKeyDown(k)
            else down = UserInputService:IsMouseButtonPressed(k) end
        end
        if down then
            local _ = GetTargetUnderCrosshair()
            Shoot()
        end
    end
    if thirdPersonActive or currentDist > 0 then
        local char = LocalPlayer.Character
        if char and char:FindFirstChild("HumanoidRootPart") then
            local hum = char:FindFirstChildOfClass("Humanoid")
            if hum and hum.Health > 0 then
                local cur = UserInputService:GetMouseLocation()
                local delta = cur - lastMousePos
                lastMousePos = cur
                if thirdPersonActive and delta.Magnitude > 0 then
                    local sens = Settings.ThirdPerson.RotationSpeed * 0.005
                    yaw = yaw - delta.X * sens
                    pitch = pitch - delta.Y * sens
                end
                if Settings.ThirdPerson.Smooth then
                    targetDist = thirdPersonActive and Settings.ThirdPerson.Distance or 0
                    currentDist = currentDist + (targetDist - currentDist) * math.min(1, (Settings.ThirdPerson.SmoothSpeed or 0.15) * 10 * dt)
                    if math.abs(currentDist - targetDist) < 0.05 then currentDist = targetDist end
                else
                    currentDist = thirdPersonActive and Settings.ThirdPerson.Distance or 0
                end
                if currentDist > 0.1 then
                    local cf = getOrbitCFrame(char, currentDist, yaw, pitch, Settings.ThirdPerson.HeightOffset)
                    if cf then Camera.CFrame = cf end
                end
            end
        end
    end
    if inventorySpyHoldActive then
        local curTarget = GetPlayerUnderCrosshairIgnoreAll()
        if curTarget ~= lastSpyTarget then
            lastSpyTarget = curTarget
            updateInventorySpy(curTarget)
        end
    elseif inventorySpyGui.Enabled then inventorySpyGui.Enabled = false end
    if frameCount % 1000 == 0 then
        local function cleanPool(pool, maxUnused)
            local vis = 0
            for _, obj in ipairs(pool) do if obj.Visible then vis = vis + 1 end end
            if #pool - vis > maxUnused then
                local newPool = {}
                for _, obj in ipairs(pool) do
                    if obj.Visible then table.insert(newPool, obj) else obj:Remove() end
                end
                return newPool
            end
            return pool
        end
        tracerPool = cleanPool(tracerPool, 20)
        improvedTracerPool = cleanPool(improvedTracerPool, 20)
        hitmarkerPool = cleanPool(hitmarkerPool, 20)
        local now = tick()
        for k, v in pairs(Settings.VisibilityCache) do if now - v.timestamp > 10 then Settings.VisibilityCache[k] = nil end end
        for k, v in pairs(Settings.WeaponCache) do if now - v.timestamp > 10 then Settings.WeaponCache[k] = nil end end
        for g in pairs(Settings.FlashGrenades) do if not g or not g.Parent then Settings.FlashGrenades[g] = nil end end
        for t in pairs(originalWeaponAttributes) do if not t or not t.Parent then originalWeaponAttributes[t] = nil end end
    end
    if watermark.Visible then
        local ct = tick()
        table.insert(frameTimes, ct - lastTime)
        if #frameTimes > 30 then table.remove(frameTimes, 1) end
        local avg = 0
        for _, v in ipairs(frameTimes) do avg = avg + v end
        avg = avg / #frameTimes
        local fps = math.floor(1 / avg)
        lastTime = ct
        local vs = Camera.ViewportSize
        watermark.Text = string.format("GGshop XENO ULTIMATE | FPS: %d", fps)
        watermark.Position = Vector2.new(vs.X / 2, 40)
    end
    GGshopCrosshair.update()
end)

