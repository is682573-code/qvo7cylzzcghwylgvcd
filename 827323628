local function UpdateLootESP()
    if not Settings.LootESP.Enabled then
        for _, esp in pairs(Settings.LargeBoxESPObjects) do
            esp.BoxOutline.Visible = false
            esp.BoxFill.Visible = false
            esp.Icon.Visible = false
            esp.NameText.Visible = false
            esp.DistanceText.Visible = false
        end
        return
    end

    local myPos = Camera.CFrame.Position
    for box, esp in pairs(Settings.LargeBoxESPObjects) do
        if not box.Parent then
            esp.BoxOutline:Remove()
            esp.BoxFill:Remove()
            esp.Icon:Remove()
            esp.NameText:Remove()
            esp.DistanceText:Remove()
            Settings.LargeBoxESPObjects[box] = nil
            continue
        end

        local primaryPart = box.PrimaryPart or (box:IsA("BasePart") and box) or box:FindFirstChildWhichIsA("BasePart")
        if not primaryPart then
            esp.BoxOutline.Visible = false
            esp.BoxFill.Visible = false
            esp.Icon.Visible = false
            esp.NameText.Visible = false
            esp.DistanceText.Visible = false
            continue
        end

        local dist = (myPos - primaryPart.Position).Magnitude
        if dist > Settings.LootESP.MaxDistance then
            esp.BoxOutline.Visible = false
            esp.BoxFill.Visible = false
            esp.Icon.Visible = false
            esp.NameText.Visible = false
            esp.DistanceText.Visible = false
            continue
        end

        local cf = primaryPart.CFrame
        local size = primaryPart.Size
        local corners = {
            cf:PointToWorldSpace(Vector3.new(-size.X/2, -size.Y/2, -size.Z/2)),
            cf:PointToWorldSpace(Vector3.new( size.X/2, -size.Y/2, -size.Z/2)),
            cf:PointToWorldSpace(Vector3.new(-size.X/2, size.Y/2, -size.Z/2)),
            cf:PointToWorldSpace(Vector3.new( size.X/2, size.Y/2, -size.Z/2)),
            cf:PointToWorldSpace(Vector3.new(-size.X/2, -size.Y/2, size.Z/2)),
            cf:PointToWorldSpace(Vector3.new( size.X/2, -size.Y/2, size.Z/2)),
            cf:PointToWorldSpace(Vector3.new(-size.X/2, size.Y/2, size.Z/2)),
            cf:PointToWorldSpace(Vector3.new( size.X/2, size.Y/2, size.Z/2)),
        }

        local minX, minY, maxX, maxY = math.huge, math.huge, -math.huge, -math.huge
        local onScreen = false
        for _, corner in ipairs(corners) do
            local vec, vis = Camera:WorldToViewportPoint(corner)
            if vis then
                onScreen = true
                minX = math.min(minX, vec.X)
                minY = math.min(minY, vec.Y)
                maxX = math.max(maxX, vec.X)
                maxY = math.max(maxY, vec.Y)
            end
        end

        if not onScreen then
            esp.BoxOutline.Visible = false
            esp.BoxFill.Visible = false
            esp.Icon.Visible = false
            esp.NameText.Visible = false
            esp.DistanceText.Visible = false
            continue
        end

        local boxPos = Vector2.new(minX, minY)
        local boxSizeVec = Vector2.new(maxX - minX, maxY - minY)

        if Settings.LootESP.Fill.Enabled then
            esp.BoxFill.Position = boxPos
            esp.BoxFill.Size = boxSizeVec
            esp.BoxFill.Color = Settings.LootESP.Fill.Color
            esp.BoxFill.Transparency = Settings.LootESP.Fill.Transparency
            esp.BoxFill.Visible = true
        else
            esp.BoxFill.Visible = false
        end

        if Settings.LootESP.Box.Enabled then
            esp.BoxOutline.Position = boxPos
            esp.BoxOutline.Size = boxSizeVec
            esp.BoxOutline.Color = Settings.LootESP.Box.Color
            esp.BoxOutline.Thickness = Settings.LootESP.Box.Thickness
            esp.BoxOutline.Visible = true
        else
            esp.BoxOutline.Visible = false
        end

        local centerX = (minX + maxX) / 2
        local centerY = (minY + maxY) / 2

        if Settings.LootESP.Icon.Enabled then
            esp.Icon.Position = Vector2.new(centerX, centerY - 20)
            esp.Icon.Visible = true
        else
            esp.Icon.Visible = false
        end

        if Settings.LootESP.Name.Enabled then
            esp.NameText.Text = "Large ABPOPA Box"
            esp.NameText.Position = Vector2.new(centerX, minY - 18)
            esp.NameText.Visible = true
        else
            esp.NameText.Visible = false
        end

        if Settings.LootESP.Distance.Enabled then
            esp.DistanceText.Text = string.format("%dm", math.floor(dist))
            esp.DistanceText.Position = Vector2.new(centerX, maxY + 4)
            esp.DistanceText.Visible = true
        else
            esp.DistanceText.Visible = false
        end
    end
end

