local function getTracerColorByAmmo(ammoType)
    if not ammoType then return Settings.Combat.BulletTracers.Color end
    local lower = ammoType:lower()
    if lower:find("ap") then
        return Color3.fromRGB(255, 100, 0)
    elseif lower:find("tracer") then
        return Color3.fromRGB(255, 255, 100)
    else
        return Settings.Combat.BulletTracers.Color
