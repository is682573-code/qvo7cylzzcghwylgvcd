-- SPEED HACK
-- ████████████████████████████████████████████████████████████
local speedHackActive = false
local targetSpeed = 16
local currentSpeed = 16
local speedResetUntil = 0

local function ApplySpeedHack()
    if not Settings.SpeedHack.Enabled then
        if speedHackActive then
            local char = LocalPlayer.Character
            if char then
                local humanoid = char:FindFirstChildOfClass("Humanoid")
                if humanoid then
                    humanoid.WalkSpeed = 16
                end
            end
            speedHackActive = false
        end
        return
    end

    local char = LocalPlayer.Character
    if not char then return end
    local humanoid = char:FindFirstChildOfClass("Humanoid")
    if not humanoid then return end

    local now = tick()
    local antiKickActive = (Settings.SpeedHack.AntiKick and now < speedResetUntil)
    local aimedAt = false
    if Settings.SpeedHack.DisableWhenAimedAt then
        aimedAt = (checkIfBeingAimed() ~= nil)
    end

    local requestedSpeed = math.min(Settings.SpeedHack.Speed, 20)

    if antiKickActive or aimedAt then
        targetSpeed = 16
    else
        targetSpeed = requestedSpeed
    end

    if Settings.SpeedHack.Smooth then
        currentSpeed = currentSpeed + (targetSpeed - currentSpeed) * 0.2
        if math.abs(currentSpeed - targetSpeed) < 0.5 then
            currentSpeed = targetSpeed
        end
    else
        currentSpeed = targetSpeed
    end

    humanoid.WalkSpeed = currentSpeed
    speedHackActive = true
end

local function TriggerAntiKick()
    if Settings.SpeedHack.AntiKick and Settings.SpeedHack.Enabled then
        speedResetUntil = tick() + Settings.SpeedHack.AntiKickDuration
    end
end

