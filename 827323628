    while true do
        task.wait(300)
        ClearVisibilityCache()
        Settings.VisibilityCache = {}
    end
end)

local function RemoveFromVisibilityCache(obj)
    if not obj then return end
    local objStr = tostring(obj)
    for key, _ in pairs(GlobalVisibilityCache) do
        if type(key) == "string" and key:find(objStr, 1, true) then
            GlobalVisibilityCache[key] = nil
        end
    end
end

