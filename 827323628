local defaultSettings = nil
local lastProfileFile = Settings.Config.SavePath .. "last_profile.txt"
local FS_AVAILABLE = (type(writefile) == "function" and type(readfile) == "function" and type(isfolder) == "function" and type(makefolder) == "function")

if not FS_AVAILABLE then
    warn("⚠️ [GGshop] Файловая система не поддерживается. Конфиги не будут сохраняться.")
    game:GetService("StarterGui"):SetCore("SendNotification", { Title = "GGshop XENO", Text = "Файловая система не поддерживается. Конфиги не будут сохраняться.", Duration = 5 })
end

local function ensureConfigPath()
    if not FS_AVAILABLE then return false end
    local path = Settings.Config.SavePath
    if not isfolder(path) then
        local success = pcall(makefolder, path)
        if not success then warn("[GGshop] Не удалось создать папку: " .. tostring(path)); return false end
    end
    return true
end

function SaveConfig(profileName)
    profileName = profileName or Settings.Config.ProfileName
    if profileName == "" then
        game:GetService("StarterGui"):SetCore("SendNotification", { Title = "GGshop XENO", Text = "Profile name cannot be empty", Duration = 2 })
        return
    end
    if not FS_AVAILABLE then
        game:GetService("StarterGui"):SetCore("SendNotification", { Title = "GGshop XENO", Text = "Файловая система не поддерживается. Сохранение невозможно.", Duration = 3 })
        return
    end
    if not ensureConfigPath() then
        game:GetService("StarterGui"):SetCore("SendNotification", { Title = "GGshop XENO", Text = "Не удалось создать папку для конфигов.", Duration = 3 })
        return
    end
    local saveTable = {
        ESP = Settings.ESP, Aimbot = Settings.Aimbot, BotsAim = Settings.BotsAim,
        Misc = Settings.Misc, DamageIndicator = Settings.DamageIndicator, Combat = Settings.Combat,
        Triggerbot = Settings.Triggerbot, AdminESP = Settings.AdminESP, Visuals = Settings.Visuals,
        BulletPhysics = Settings.BulletPhysics, SpeedHack = Settings.SpeedHack, AutoLoot = Settings.AutoLoot,
        WeaponStats = Settings.WeaponStats, BulletTracersImproved = Settings.BulletTracersImproved,
        NPCESP = Settings.NPCESP, Zoom = Settings.Zoom, MapESP = Settings.MapESP,
        Customization = Settings.Customization, InventorySpy = Settings.InventorySpy,
        NoVisors = Settings.NoVisors, NoGrass = Settings.NoGrass, NoFlashbang = Settings.NoFlashbang,
        LootESP = Settings.LootESP, ThirdPerson = Settings.ThirdPerson, Crosshair = Settings.Crosshair,
        MenuKey = Settings.MenuKey,
    }
    local success, json = pcall(function() return HttpService:JSONEncode(saveTable) end)
    if not success then
        game:GetService("StarterGui"):SetCore("SendNotification", { Title = "GGshop XENO", Text = "Ошибка при создании JSON", Duration = 2 })
        return
    end
    local path = Settings.Config.SavePath .. profileName .. ".json"
    local writeSuccess = pcall(function() writefile(path, json) end)
    if writeSuccess then
        pcall(function() writefile(lastProfileFile, profileName) end)
        game:GetService("StarterGui"):SetCore("SendNotification", { Title = "GGshop XENO", Text = "Config '" .. profileName .. "' saved!", Duration = 2 })
    else
        game:GetService("StarterGui"):SetCore("SendNotification", { Title = "GGshop XENO", Text = "Failed to write config file", Duration = 2 })
    end
end

function LoadConfig(profileName)
    profileName = profileName or Settings.Config.ProfileName
    if profileName == "" then
        game:GetService("StarterGui"):SetCore("SendNotification", { Title = "GGshop XENO", Text = "Profile name cannot be empty", Duration = 2 })
        return
    end
    if not FS_AVAILABLE then
        game:GetService("StarterGui"):SetCore("SendNotification", { Title = "GGshop XENO", Text = "Файловая система не поддерживается. Загрузка невозможна.", Duration = 3 })
        return
    end
    local path = Settings.Config.SavePath .. profileName .. ".json"
    local success, data = pcall(readfile, path)
    if not success then
        game:GetService("StarterGui"):SetCore("SendNotification", { Title = "GGshop XENO", Text = "Config not found", Duration = 2 })
        return
    end
    local decoded = HttpService:JSONDecode(data)
    if not decoded then
        game:GetService("StarterGui"):SetCore("SendNotification", { Title = "GGshop XENO", Text = "Invalid config file", Duration = 2 })
        return
    end
    local function merge(t, s)
        for k, v in pairs(s) do
            if type(v) == "table" and type(t[k]) == "table" then merge(t[k], v) else t[k] = v end
        end
    end
    merge(Settings, decoded)
    if Settings.Crosshair and Settings.Crosshair.Style then
        Settings.Crosshair.Style = tonumber(Settings.Crosshair.Style) or 1
    end
    ApplyNightVision(Settings.Misc.NightVision)
    ApplyNoGrass(Settings.NoGrass.Enabled)
    ApplyNoVisors(Settings.NoVisors.Enabled)
    game:GetService("StarterGui"):SetCore("SendNotification", { Title = "GGshop XENO", Text = "Config '" .. profileName .. "' loaded!", Duration = 2 })
    updateTabContent(currentTab)
    GGshopCrosshair.update()
end

function ResetToDefaults()
    if not defaultSettings then defaultSettings = HttpService:JSONDecode(HttpService:JSONEncode(Settings)) end
    local function merge(t, s)
        for k, v in pairs(s) do
            if type(v) == "table" and type(t[k]) == "table" then merge(t[k], v) else t[k] = v end
        end
    end
    merge(Settings, defaultSettings)
    if Settings.Crosshair and Settings.Crosshair.Style then
        Settings.Crosshair.Style = tonumber(Settings.Crosshair.Style) or 1
    end
    ApplyNightVision(Settings.Misc.NightVision)
    ApplyNoGrass(Settings.NoGrass.Enabled)
    ApplyNoVisors(Settings.NoVisors.Enabled)
    game:GetService("StarterGui"):SetCore("SendNotification", { Title = "GGshop XENO", Text = "Settings reset to defaults", Duration = 2 })
    updateTabContent(currentTab)
    GGshopCrosshair.update()
end

