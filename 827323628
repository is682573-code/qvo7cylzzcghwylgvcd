-- WEAPON MODIFICATIONS (NO RECOIL, NO SPREAD, ETC.)
-- ████████████████████████████████████████████████████████████
local originalWeaponAttributes = {}

local function ApplyWeaponMods()
    if not (Settings.Combat.NoSpread or Settings.Combat.NoJumpSpread or Settings.Combat.NoSway or Settings.Combat.NoBreath or Settings.Combat.NoCameraKick) then
        for tool, attrs in pairs(originalWeaponAttributes) do
            if tool and tool.Parent then
                for attrName, originalValue in pairs(attrs) do
                    pcall(function() tool:SetAttribute(attrName, originalValue) end)
                end
            end
            originalWeaponAttributes[tool] = nil
        end
        return
    end

    local char = LocalPlayer.Character
    if not char then return end
    local tool = char:FindFirstChildOfClass("Tool")
    if not tool then return end

    local weaponName = tool.Name
    local stats = Settings.WeaponStats[weaponName] or Settings.WeaponStats.Default

    local function modifyAttribute(attrName, multiplier)
        if multiplier == nil then return end
        local current = tool:GetAttribute(attrName)
        if current == nil then return end

        if not originalWeaponAttributes[tool] then originalWeaponAttributes[tool] = {} end
        if originalWeaponAttributes[tool][attrName] == nil then
            originalWeaponAttributes[tool][attrName] = current
        end

        local newValue = current * (1 - multiplier)
        tool:SetAttribute(attrName, newValue)
    end

    if Settings.Combat.NoSpread then
        modifyAttribute("Spread", Settings.Combat.GlobalSpreadMult)
    end
    if Settings.Combat.NoJumpSpread then
        modifyAttribute("JumpSpread", Settings.Combat.GlobalJumpSpreadMult)
    end

    if stats.SpreadMult and Settings.Combat.NoSpread then
        modifyAttribute("Spread", stats.SpreadMult)
    end

    if Settings.Combat.NoSway then
        modifyAttribute("Sway", 1)
    end
    if Settings.Combat.NoBreath then
        modifyAttribute("Breath", 1)
    end
    if Settings.Combat.NoCameraKick then
        modifyAttribute("CameraKick", 1)
    end
end

local function setupWeaponTracking()
    local function trackCharacter(character)
        if not character then return end
        character.ChildAdded:Connect(function(child)
            if child:IsA("Tool") then
                originalWeaponAttributes = {}
                ApplyWeaponMods()
            end
        end)
        for _, child in ipairs(character:GetChildren()) do
            if child:IsA("Tool") then
                ApplyWeaponMods()
            end
        end
    end

    if LocalPlayer.Character then
        trackCharacter(LocalPlayer.Character)
    end
    LocalPlayer.CharacterAdded:Connect(trackCharacter)
end
setupWeaponTracking()

