-- ████████████████████████████████████████████████████████████
-- ФУНКЦИИ ДЛЯ ОРУЖИЯ
-- ████████████████████████████████████████████████████████████
local function isPrimaryWeapon(weaponName)
    for _, name in ipairs(WeaponType.Primary) do
        if weaponName:find(name, 1, true) then return true end
    end
    return false
end

local function isSecondaryWeapon(weaponName)
    for _, name in ipairs(WeaponType.Secondary) do
        if weaponName:find(name, 1, true) then return true end
    end
    return false
end

local function GetPlayerWeaponInfo(plr)
    local now = tick()
    if Settings.WeaponCache[plr] and (now - Settings.WeaponCache[plr].timestamp) < Settings.WEAPON_CACHE_DURATION then
        return Settings.WeaponCache[plr].primary, Settings.WeaponCache[plr].secondary
    end
    local primaryWeapon, secondaryWeapon = "", ""
    local primaryDamage, primaryPen, secondaryDamage, secondaryPen = 0, 0, 0, 0
    local char = plr.Character
    local function isWeapon(obj)
        if not obj then return false end
        if obj:IsA("Tool") then return true end
        if obj:IsA("Model") and obj:FindFirstChild("Handle") then return true end
        for pattern in pairs(weaponToAmmo) do
            if obj.Name:find(pattern, 1, true) then return true end
        end
        return false
    end
    local function getWeaponDamage(weaponObj)
        if not weaponObj then return 0, 0 end
        local ammoType
        pcall(function() ammoType = weaponObj:GetAttribute("AmmoType") end)
        if not ammoType then
            local ammoObj = weaponObj:FindFirstChild("Ammo")
            if ammoObj then
                ammoType = (ammoObj:IsA("StringValue") or ammoObj:IsA("NumberValue")) and ammoObj.Value or ammoObj.Name
            end
        end
        if ammoType and AmmoData[ammoType] then
            return AmmoData[ammoType].Damage or 0, AmmoData[ammoType].ArmorPen or 0
        end
        for weaponPattern, ammoKey in pairs(weaponToAmmo) do
            if weaponObj.Name:find(weaponPattern, 1, true) and AmmoData[ammoKey] then
                return AmmoData[ammoKey].Damage or 0, AmmoData[ammoKey].ArmorPen or 0
            end
        end
        return 0, 0
    end
    if char then
        local weapons = {}
        for _, child in ipairs(char:GetChildren()) do
            if isWeapon(child) and not child:IsA("Accessory") then
                table.insert(weapons, child)
            end
        end
        for _, weapon in ipairs(weapons) do
            local name = weapon.Name
            if isPrimaryWeapon(name) then
                primaryWeapon = name
                primaryDamage, primaryPen = getWeaponDamage(weapon)
            elseif isSecondaryWeapon(name) then
                secondaryWeapon = name
                secondaryDamage, secondaryPen = getWeaponDamage(weapon)
            end
        end
    end
    local cache = { primary = { name = primaryWeapon, damage = primaryDamage, pen = primaryPen }, secondary = { name = secondaryWeapon, damage = secondaryDamage, pen = secondaryPen }, timestamp = now }
    Settings.WeaponCache[plr] = cache
    return cache.primary, cache.secondary
end

-- ████████████████████████████████████████████████████████████
-- ФУНКЦИЯ ДЛЯ БОССОВ
-- ████████████████████████████████████████████████████████████
local function IsBoss(character)
    if not character then return false, nil end
    local humanoid = character:FindFirstChildOfClass("Humanoid")
    if not humanoid then return false, nil end
    local nameLower = character.Name:lower()
    for bossName in pairs(Settings.BossNames) do
        if nameLower:find(bossName:lower(), 1, true) then return true, bossName end
    end
    if humanoid.MaxHealth > 150 then
        if nameLower:find("dozer") or nameLower:find("heavy") then return true, "Dozer"
        elseif nameLower:find("anton") or nameLower:find("bandit") then return true, "Anton"
        else return true, "Unknown Boss" end
    end
    return false, nil
end

-- ████████████████████████████████████████████████████████████
-- ФУНКЦИЯ ПРОВЕРКИ ВИДИМОСТИ (РЕЙКАСТ С КЭШЕМ)
-- ████████████████████████████████████████████████████████████
local function IsTargetVisible(targetChar, checkParts, extraIgnore)
    if not targetChar then return false end
    local currentCam = Workspace.CurrentCamera
    local ignoreList = {LocalPlayer.Character, targetChar, currentCam}
    if extraIgnore then
        for _, obj in ipairs(extraIgnore) do table.insert(ignoreList, obj) end
    end
    local origin = currentCam.CFrame.Position
    for _, partName in ipairs(checkParts) do
        local targetPart = targetChar:FindFirstChild(partName)
        if targetPart and targetPart:IsA("BasePart") then
            local key = tostring(targetChar) .. "_" .. partName
            local now = tick()
            local cached = GlobalVisibilityCache[key]
            if cached and now - cached.timestamp < VISIBILITY_CACHE_TTL then
                if cached.visible then return true end
            else
                local direction = (targetPart.Position - origin).Unit * (targetPart.Position - origin).Magnitude
                local raycastParams = RaycastParams.new()
                raycastParams.FilterType = Enum.RaycastFilterType.Blacklist
                raycastParams.FilterDescendantsInstances = ignoreList
                raycastParams.IgnoreWater = true
                local result = Workspace:Raycast(origin, direction, raycastParams)
                local visible = not result
                GlobalVisibilityCache[key] = { visible = visible, timestamp = now }
                if visible then return true end
            end
        end
    end
    return false
end

