local function parseInventory(player)
    local data = { equipped = {}, inventory = {}, keychain = {}, weapons = {}, misc = {} }
    local char = player.Character
    if char then
        for _, obj in ipairs(char:GetChildren()) do
            if obj:IsA("Accessory") or (obj:IsA("Model") and obj:FindFirstChildOfClass("Humanoid") == nil) then
                table.insert(data.equipped, obj.Name)
            end
        end
    end
    local playerData = ReplicatedStorage:FindFirstChild("Players") and ReplicatedStorage.Players:FindFirstChild(player.Name)
    if playerData then
        local inv = playerData:FindFirstChild("Inventory")
        if inv then
            for _, item in ipairs(inv:GetChildren()) do
                table.insert(data.inventory, item.Name)
            end
        end
        local keychain = playerData:FindFirstChild("KeyChain")
        if keychain then
            for _, key in ipairs(keychain:GetChildren()) do
                table.insert(data.keychain, key.Name)
            end
        end
        for _, child in ipairs(playerData:GetChildren()) do
            if child:IsA("Folder") and child.Name:find("Weapon") then
                for _, weapon in ipairs(child:GetChildren()) do
                    table.insert(data.weapons, weapon.Name)
                end
            end
        end
    end
    for _, tool in ipairs(player.Backpack:GetChildren()) do
        table.insert(data.inventory, "[Tool] " .. tool.Name)
    end
    return data
end

local function updateInventoryDisplay()
    for _, child in ipairs(pageFrameSpy:GetChildren()) do
        if child ~= pageLayoutSpy then child:Destroy() end
    end
    if not currentSpyTarget then
        pageLabelSpy.Text = "No target"
        return
    end
    local data = inventoryDataSpy
    local allItems = {}
    local categories = {"equipped", "inventory", "keychain", "weapons", "misc"}
    for _, cat in ipairs(categories) do
        for _, item in ipairs(data[cat] or {}) do
            table.insert(allItems, {cat = cat, name = item})
        end
    end
    totalPagesSpy = math.max(1, math.ceil(#allItems / 10))
    if currentPageSpy > totalPagesSpy then currentPageSpy = totalPagesSpy end
    pageLabelSpy.Text = string.format("Page %d/%d", currentPageSpy, totalPagesSpy)
    prevPageBtnSpy.Visible = (currentPageSpy > 1)
    nextPageBtnSpy.Visible = (currentPageSpy < totalPagesSpy)

    local startIdx = (currentPageSpy - 1) * 10 + 1
    local endIdx = math.min(startIdx + 9, #allItems)
    for i = startIdx, endIdx do
        local item = allItems[i]
        local itemLabel = Instance.new("TextLabel")
        itemLabel.Parent = pageFrameSpy
        itemLabel.Size = UDim2.new(1, -5, 0, 20)
        itemLabel.BackgroundTransparency = 1
        local icon = Settings.InventorySpy.ShowIcons and "🔹 " or ""
        itemLabel.Text = icon .. "[" .. item.cat .. "] " .. item.name
        itemLabel.TextColor3 = COLORS.INVENTORY_TEXT
        itemLabel.Font = Enum.Font.Gotham
        itemLabel.TextSize = 14
        itemLabel.TextXAlignment = Enum.TextXAlignment.Left
    end
    pageFrameSpy.CanvasSize = UDim2.new(0, 0, 0, pageLayoutSpy.AbsoluteContentSize.Y + 10)
end

prevPageBtnSpy.MouseButton1Click:Connect(function()
    if currentPageSpy > 1 then
        currentPageSpy = currentPageSpy - 1
        updateInventoryDisplay()
    end
end)

nextPageBtnSpy.MouseButton1Click:Connect(function()
    if currentPageSpy < totalPagesSpy then
        currentPageSpy = currentPageSpy + 1
        updateInventoryDisplay()
    end
end)

local function updateInventorySpy(target)
    if not target then
        inventorySpyGui.Enabled = false
        return
    end
    currentSpyTarget = target
    inventoryDataSpy = parseInventory(target)
    currentPageSpy = 1
    updateInventoryDisplay()
    inventorySpyGui.Enabled = true
end

